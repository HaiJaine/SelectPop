{
  "name": "selectpop",
  "version": "0.1.0",
  "description": "Portable Windows text selection toolbar built with Electron.",
  "main": "main/main.js",
  "type": "module",
  "scripts": {
    "dev": "npm run build:native && electron .",
    "build:native": "node scripts/build-native.mjs",
    "test": "node --test main/webdav-sync.test.js main/launch-on-boot.test.js",
    "postinstall": "electron-builder install-app-deps",
    "pack:portable": "npm run build:native && node scripts/run-electron-builder.mjs --config electron-builder.yml --win portable --x64",
    "dist:portable": "npm run build:native && node scripts/run-electron-builder.mjs --config electron-builder.yml --win portable --x64 && node scripts/dist-portable.mjs",
    "smoke:portable": "node scripts/smoke-portable.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "electron-store": "latest",
    "highlight.js": "latest",
    "mathjax-full": "latest",
    "rehype-mathjax": "latest",
    "rehype-raw": "latest",
    "rehype-stringify": "latest",
    "remark-breaks": "latest",
    "remark-gfm": "latest",
    "remark-math": "latest",
    "remark-parse": "latest",
    "remark-rehype": "latest",
    "uiohook-napi": "latest",
    "unified": "latest"
  },
  "devDependencies": {
    "electron": "latest",
    "electron-builder": "latest"
  }
}
